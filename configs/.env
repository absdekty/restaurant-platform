# Адресы и порты gRPC
AUTH_GRPC_LISTENER=localhost:50051
USER_GRPC_LISTENER=localhost:50052

# Сертификаты
CA_CERT=certs/ca/ca-cert.pem

AUTH_CERT=certs/auth/server-cert.pem
AUTH_KEY=certs/auth/server-key.pem

USER_CERT=certs/user/server-cert.pem
USER_KEY=certs/user/server-key.pem

GATEWAY_CERT=certs/gateway/client-cert.pem
GATEWAY_KEY=certs/gateway/client-key.pem